# 破壁 / GlobalInfo — builder secrets (the app needs none at read time)

# Required for Claude enrichment (faithful translation + summary + ticker tagging).
# Without it, the builder still produces a feed of raw English items marked
# "翻译待生成" and the app renders fine.
ANTHROPIC_API_KEY=

# Optional. Model used for enrichment in the builder. Defaults to a cheap Haiku.
ENRICH_MODEL=claude-haiku-4-5-20251001

# Optional. X / Twitter ingestion (Zara pattern). Absent => X step skipped entirely.
# Real daily use wants the X API Basic tier (~$200/mo); free tier is too small.
X_BEARER_TOKEN=
